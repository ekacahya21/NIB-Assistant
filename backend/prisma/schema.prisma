datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Draft {
  id                String   @id
  namaPemilik       String   @map("nama_pemilik")
  nik               String
  tanggalLahir      String   @map("tanggal_lahir")
  nomorHp           String   @map("nomor_hp")
  email             String
  alamatUsaha       String   @map("alamat_usaha")
  alamatKtp         String?  @map("alamat_ktp")
  provinsiKtp       String?  @map("provinsi_ktp")
  kotaKabupatenKtp  String?  @map("kota_kabupaten_ktp")
  kecamatanKtp      String?  @map("kecamatan_ktp")
  kelurahanKtp      String?  @map("kelurahan_ktp")
  kodePosKtp        String?  @map("kode_pos_ktp")
  provinsi          String
  kotaKabupaten     String   @map("kota_kabupaten")
  kecamatan         String
  kelurahan         String
  kodePos           String   @map("kode_pos")
  namaUsaha         String   @map("nama_usaha")
  ceritaUsaha       String   @map("cerita_usaha")
  modalUsaha        String   @map("modal_usaha")
  jumlahPekerja     String   @map("jumlah_pekerja")
  kbliCode          String?  @map("kbli_code")
  kbliTitle         String?  @map("kbli_title")
  jenisKelamin      String?  @map("jenis_kelamin")
  latitude          String?
  longitude         String?
  luasTanah         String?  @map("luas_tanah")
  fotoLokasi        String?  @map("foto_lokasi")
  status            String   @default("DRAFT")
  automationDuration Int?     @map("automation_duration")
  sessionId         String?  @map("session_id")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("drafts")
}

